---
import { formatDisplayDate } from '../utils/formatDate';

interface Props {
  date: Date;
  primary: string;
  readTime?: string;
  extra?: string;
  className?: string;
}

const {
  date,
  primary,
  readTime,
  extra,
  className = ''
} = Astro.props;

const formattedDate = formatDisplayDate(date, 'long');

const items = [
  formattedDate,
  primary,
  readTime,
  extra
].filter(Boolean);
---

<div class:list={['meta-row', 'entry-meta', className]}>
  {items.map((item) => (
    <span class="meta-pill">{item}</span>
  ))}
</div>
