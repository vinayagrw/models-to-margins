---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About | Models to Margins"
  description="About the Models to Margins publication and its business-first approach to AI research."
  currentPath="/about"
>
  <section class="article-shell">
    <header>
      <span class="eyebrow">About</span>
      <h1>Research built for operators, not just for feeds.</h1>
      <p class="lead">
        Models to Margins is a publication system for turning AI and operations research into something a buyer,
        strategist, or investor can actually use: structured briefs, evidence-aware deep dives, and interactive pages
        that make workflow design legible.
      </p>
    </header>

    <div class="content-grid section-block">
      <div class="glass-card">
        <h3>What we publish</h3>
        <p>Operator briefs, market studies, workflow maps, and interactive explainers focused on business value.</p>
      </div>
      <div class="glass-card">
        <h3>How we work</h3>
        <p>Separate fact from inference, stay conservative on ROI, and prefer workflow clarity over model theater.</p>
      </div>
      <div class="glass-card">
        <h3>Why Astro</h3>
        <p>Content collections keep the publication scalable while static interactive assets stay fast and portable.</p>
      </div>
    </div>
  </section>
</BaseLayout>
