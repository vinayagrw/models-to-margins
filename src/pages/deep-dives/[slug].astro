---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryMeta from '../../components/EntryMeta.astro';
import BackLink from '../../components/BackLink.astro';

export async function getStaticPaths() {
  // Slugs that have their own dedicated route file in this directory.
  // Skip them here so the build doesn't try to generate the same path twice.
  // (Defined inside getStaticPaths because Astro hoists this function
  // into a separate scope at build time and cannot reach module-level consts.)
  const DEDICATED_SLUGS = new Set(['harness-engineering']);

  const entries = await getCollection('deep-dives');
  return entries
    .filter((entry) => !DEDICATED_SLUGS.has(entry.id))
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry }
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={`${entry.data.title} | Models to Margins`}
  description={entry.data.summary}
  currentPath="/deep-dives"
>
  <article class="article-shell">
    <header>
      <span class="eyebrow">Deep Dive</span>
      <h1>{entry.data.title}</h1>
      <p class="lead">{entry.data.summary}</p>
      <BackLink href="/deep-dives" label="Back to Deep Dives" />
      <EntryMeta
        date={entry.data.pubDate}
        primary={entry.data.geography}
        readTime={entry.data.readTime}
        extra={entry.data.horizon}
      />
      <div class="tag-row">
        {entry.data.tags.map((tag: string) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </header>
    <div class="article-body">
      <Content />
    </div>
  </article>
</BaseLayout>
