---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CollectionCard from '../../components/CollectionCard.astro';
import { formatDisplayDate } from '../../utils/formatDate';
import { getVisibleBriefs, isPageVisible, getBriefHref } from '../../utils/site-data';

const briefs = await getVisibleBriefs();
const showCollectionLinkingNote = !isPageVisible('/briefs');
---

<BaseLayout
  title="Brief | Models to Margins"
  description="Curated flagship reads that synthesize the signal quickly and make the deeper operating questions easier to navigate."
  currentPath="/briefs"
>
  <section class="article-shell">
    <header>
      <span class="eyebrow warm">Brief</span>
      <h1>A faster read on the bigger shift.</h1>
      <p class="lead">Curated flagship reads that synthesize the signal quickly and make the deeper operating questions easier to navigate.</p>
    </header>
    {showCollectionLinkingNote && (
      <div class="glass-card section-block">
        <h3>Brief is hidden from app navigation right now.</h3>
        <p>This index still works directly by URL, but the shared visibility config is currently removing `/briefs` from discovery surfaces elsewhere in the app.</p>
      </div>
    )}
    <div class="content-grid section-block">
      {briefs.map((entry) => (
        <CollectionCard
          href={getBriefHref(entry)}
          kicker="Brief"
          title={entry.data.title}
          summary={entry.data.summary}
          date={formatDisplayDate(entry.data.pubDate, 'short')}
          meta={entry.data.readTime ?? entry.data.industry}
        />
      ))}
    </div>
  </section>
</BaseLayout>
