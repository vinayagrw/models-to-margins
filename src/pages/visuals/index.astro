---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CollectionCard from '../../components/CollectionCard.astro';

const visuals = (await getCollection('visuals')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Interactive Archive | Models to Margins"
  description="Archived interactive pages and command-center style experiences."
  currentPath="/visuals"
>
  <section class="article-shell">
    <header>
      <span class="eyebrow warm">Archive</span>
      <h1>Interactive archive.</h1>
      <p class="lead">Older interactive pages remain available here, but the public site now centers on one brief and one deep dive.</p>
    </header>
    <div class="content-grid section-block">
      {visuals.map((entry) => (
        <CollectionCard
          href={`/visuals/${entry.id}`}
          kicker="Interactive"
          title={entry.data.title}
          summary={entry.data.summary}
          date={entry.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          meta={entry.data.visualType}
        />
      ))}
    </div>
  </section>
</BaseLayout>
